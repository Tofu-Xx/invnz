{
  // 拼音转汉字编码映射表 - Pinyin to Han character CJK Compatibility Ideograph mapping
  
  initial: {
    // 声母编码 - Initial consonants mapping
    b: "⿰匕",      // b → 匕
    p: "⿰片",      // p → 片
    m: "⿰木",      // m → 木
    f: "⿰方",      // f → 方
    d: "⿰丁",      // d → 丁
    t: "⿰田",      // t → 田
    n: "⿰牛",      // n → 牛
    l: "⿰立",      // l → 立
    g: "⿱工",      // g → 工
    k: "⿰口",      // k → 口
    h: "⿰火",      // h → 火
    j: "⿱久",      // j → 久
    q: "⿰七",      // q → 七
    x: "⿰忄",      // x → 忄
    zh: "⿰止",     // zh → 止
    ch: "⿸厂",     // ch → 厂
    sh: "⿰山",     // sh → 山
    r: "⿰日",      // r → 日
    z: "⿰子",      // z → 子
    c: "⿱艹",      // c → 艹
    s: "⿰纟",      // s → 纟
  },
  
  vowel: {
    // 韵母编码 - Vowel/final mapping
    i: "⿱一",      // [i] → 一
    u: "⿱土",      // [u] → 土
    v: "⿱女",      // [v/ü] → 女
    a: "⿱才",      // [a] → 才
    aa: "⿱八",     // [aa] → 八
    o: "⿱斗",      // [o] → 斗
    ao: "⿱刀",     // [ao] → 刀
    e: "⿱贝",      // [e] → 贝
    ee: "⿱么",     // [ee] → 么
    er: "⿱耳",     // [er] → 耳
  },
  
  final: {
    // 韵尾编码 - Final ending mapping
    n: "⿵冂",      // [n] → 冂
    g: "⿹勹",      // [ng] → 勹
  },
}
