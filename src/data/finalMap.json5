{
  // 韵母映射表 - Final vowels/endings
  a: "aa",       // [a] → [aa]
  ai: "a",       // [ai] → [a]
  ao: "ao",      // [ao] → [ao]
  o: "ee",       // [o] → [ee]
  e: "ee",       // [e] → [ee]
  ei: "e",       // [ei] → [e]
  er: "er",      // [er] → [er]
  i: "i",        // [i] → [i]
  ou: "o",       // [ou] → [o]
  u: "u",        // [u] → [u]
  ü: "v",        // [ü] → [v]
  
  // 鼻韵母 - Nasal endings
  an: "an",      // [an] → [an]
  ang: "ag",     // [ang] → [ag]
  en: "en",      // [en] → [en]
  eng: "eg",     // [eng] → [eg]
  
  // 复合韵母 - Complex finals
  ia: "iaa",     // [ia] → [iaa]
  iao: "iao",    // [iao] → [iao]
  ie: "ia",      // [ie] → [ia]
  in: "in",      // [in] → [in]
  ing: "ig",     // [ing] → [ig]
  iu: "io",      // [iu] → [io]
  ong: "ug",     // [ong] → [ug]
  ua: "uaa",     // [ua] → [uaa]
  uai: "ua",     // [uai] → [ua]
  ui: "ue",      // [ui] → [ue]
  un: "un",      // [un] → [un]
  uo: "uee",     // [uo] → [uee]
  üe: "va",      // [üe] → [va]
  ün: "vn",      // [ün] → [vn]
  
  // 三字组合韵母
  ian: "ian",    // [ian] → [ian]
  iang: "iag",   // [iang] → [iag]
  iong: "iug",   // [iong] → [iug]
  uan: "uan",    // [uan] → [uan]
  uang: "uag",   // [uang] → [uag]
  üan: "van",    // [üan] → [van]
}
