{
  "name": "invnz",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "Convert pinyin to CJK-component-based representation",
  "author": "",
  "license": "MIT",
  "keywords": [
    "pinyin",
    "hanzi",
    "cjk"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "release": "bumpp -no-push && nr build && pnpm publish",
    "pinyin": "esno scripts/pinyin.ts",
    "gentest": "esno scripts/gentest.ts",
    "test": "vitest run",
    "test:fail": "vitest run --reporter=./scripts/reporter.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "up": "taze major -I",
    "docs": "vitepress dev tutorial",
    "docs:build": "vitepress build tutorial",
    "docs:preview": "vitepress preview tutorial",
    "docs:deploy": "bash scripts/deploy-docs.sh"

  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@antfu/ni": "^30.1.0",
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-format": "^2.0.1",
    "esno": "^4.8.0",
    "taze": "^19.13.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "sharp",
      "workerd"
    ]
  }
}
